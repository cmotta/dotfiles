#!/usr/bin/env bash
# Create a tmux dev workspace with Claude Code + 3 terminal panes.
#
# Layout:
#   ┌──────────────┬──────────┐
#   │              │          │
#   │   Main       │  Claude  │
#   │  Terminal    │  (full   │
#   │   (large)   │  height) │
#   │              │          │
#   ├──────┬───────┤          │
#   │ dev  │ logs  │          │
#   │server│ tail  │          │
#   └──────┴───────┴──────────┘
#
# Usage:
#   dev-workspace           # session named "dev"
#   dev-workspace myproject # session named "myproject"

set -euo pipefail

SESSION="${1:-dev}"
BASE_INDEX=$(tmux show-option -gv pane-base-index 2>/dev/null || echo 0)

# Attach if session already exists
if tmux has-session -t "$SESSION" 2>/dev/null; then
  exec tmux attach-session -t "$SESSION"
fi

export CLAUDE_TMUX_SESSION="$SESSION"

# Pane $BASE_INDEX: main terminal (top-left)
tmux new-session -d -s "$SESSION"

# Pane $((BASE_INDEX+1)): Claude Code (full-height right, 40%)
tmux split-window -h -t "$SESSION:.$BASE_INDEX" -p 40 \
  "CLAUDE_TMUX_SESSION=$SESSION claude; exec $SHELL"

# Select main terminal and split bottom 30% for dev server
# Pane $((BASE_INDEX+2)): dev server (bottom-left)
tmux split-window -v -t "$SESSION:.$BASE_INDEX" -p 30

# Split dev server pane in half for logs
# Pane $((BASE_INDEX+3)): logs tail (bottom-right of left side)
tmux split-window -h -t "$SESSION:.$((BASE_INDEX+2))"

# Focus on main terminal (top-left)
tmux select-pane -t "$SESSION:.$BASE_INDEX"

# Attach
exec tmux attach-session -t "$SESSION"
