#!/usr/bin/env bash
# Create a tmux dev workspace with Claude Code + 3 terminal panes.
#
# Layout:
#   ┌──────────────┬──────────┐
#   │              │          │
#   │   Main       │  Claude  │
#   │  Terminal    │  (full   │
#   │   (large)   │  height) │
#   │              │          │
#   ├──────┬───────┤          │
#   │ dev  │ logs  │          │
#   │server│ tail  │          │
#   └──────┴───────┴──────────┘
#
# Usage:
#   dev-workspace           # session named "dev"
#   dev-workspace myproject # session named "myproject"

set -euo pipefail

SESSION="${1:-dev}"

# Attach if session already exists
if tmux has-session -t "$SESSION" 2>/dev/null; then
  exec tmux attach-session -t "$SESSION"
fi

export CLAUDE_TMUX_SESSION="$SESSION"

# Create session — first pane is main terminal
tmux new-session -d -s "$SESSION"
MAIN=$(tmux list-panes -t "$SESSION" -F '#{pane_id}')

# Split right 40% for Claude Code (full height)
tmux split-window -h -t "$MAIN" -p 40 \
  "CLAUDE_TMUX_SESSION=$SESSION claude; exec $SHELL"

# Split main terminal bottom 30% for dev server
tmux split-window -v -t "$MAIN" -p 30

# DEV is now the active (bottom-left) pane
DEV=$(tmux list-panes -t "$SESSION" -F '#{pane_id} #{pane_top}' \
  | sort -k2 -rn | head -1 | awk '{print $1}')

# Split dev server pane in half for logs
tmux split-window -h -t "$DEV" -p 50

# Focus on main terminal (top-left)
tmux select-pane -t "$MAIN"

# Attach
exec tmux attach-session -t "$SESSION"
