#!/usr/bin/env bash
# Create a tmux dev workspace with Claude Code + 3 terminal panes.
#
# Layout:
#   ┌──────────────┬──────────┐
#   │              │          │
#   │   Main       │  Claude  │
#   │  Terminal    │  (full   │
#   │   (large)   │  height) │
#   │              │          │
#   ├──────┬───────┤          │
#   │ dev  │ logs  │          │
#   │server│ tail  │          │
#   └──────┴───────┴──────────┘
#
# Usage:
#   dev-workspace           # session named "dev"
#   dev-workspace myproject # session named "myproject"

set -euo pipefail

SESSION="${1:-dev}"

# Attach if session already exists
if tmux has-session -t "$SESSION" 2>/dev/null; then
  exec tmux attach-session -t "$SESSION"
fi

export CLAUDE_TMUX_SESSION="$SESSION"

# Create session — first pane is main terminal
tmux new-session -d -s "$SESSION"

# Split right 40% for Claude Code (full height)
tmux split-window -h -t "$SESSION" -p 40 \
  "CLAUDE_TMUX_SESSION=$SESSION claude; exec $SHELL"

# Go back to the left pane (main terminal)
tmux select-pane -t "$SESSION" -L

# Split bottom 30% for dev server
tmux split-window -v -t "$SESSION" -p 30

# Split the dev server pane (currently active) in half for logs
tmux split-window -h -t "$SESSION" -p 50

# Focus on main terminal (top-left)
tmux select-pane -t "$SESSION" -U

# Attach
exec tmux attach-session -t "$SESSION"
